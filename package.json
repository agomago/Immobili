{
  "name": "immobili-manager",
  "version": "1.0.0",
  "description": "Gestione immobili, spese, affitti e documenti",
  "author": "Agostino D'Agostino <agostino.dagostino@gmail.com>",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "exceljs": "^4.4.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "leaflet": "^1.9.4",
    "node-notifier": "^10.0.1",
    "node-schedule": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "react-leaflet": "^5.0.0",
    "tesseract.js": "^5.0.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "lucide-react": "^0.344.0",
    "playwright-core": "^1.60.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-router-dom": "^6.22.1",
    "recharts": "^2.12.2",
    "tailwindcss": "^3.4.1",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.immobili.manager",
    "productName": "Immobili Manager",
    "copyright": "Copyright © 2026 Immobili Manager",
    "directories": {
      "output": "dist-app",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/electron-vite/**",
      "!node_modules/vite/**",
      "!node_modules/@vitejs/**",
      "!node_modules/playwright-core/**",
      "!node_modules/autoprefixer/**",
      "!node_modules/postcss/**",
      "!node_modules/tailwindcss/**",
      "!node_modules/typescript/**",
      "!node_modules/.cache/**",
      "!**/*.map",
      "!**/.git/**"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/tesseract.js/**/*",
      "node_modules/node-notifier/**/*",
      "node_modules/pdf-parse/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/tray-icon.png",
        "to": "resources/tray-icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "ImmobiliManager-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Immobili Manager",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    },
    "npmRebuild": true,
    "buildDependenciesFromSource": false
  }
}
